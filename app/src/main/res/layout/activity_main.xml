<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="18dp"
    android:background="@drawable/bg_aura_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_aura"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ContactAura"
            android:textColor="@color/aura_text_dark"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Lis, synchronise et recherche tes contacts depuis une API distante."
            android:textColor="@color/aura_text_soft"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvAuraStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_status_chip"
            android:paddingLeft="14dp"
            android:paddingTop="7dp"
            android:paddingRight="14dp"
            android:paddingBottom="7dp"
            android:text="Prêt à charger les contacts"
            android:textColor="@color/aura_primary_dark"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <Button
        android:id="@+id/btnImportLocal"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_button_primary"
        android:text="Charger les contacts du téléphone"
        android:textAllCaps="false"
        android:textColor="@color/aura_white"
        android:textSize="15sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnSendCloud"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_button_secondary"
        android:text="Synchroniser vers le serveur"
        android:textAllCaps="false"
        android:textColor="@color/aura_white"
        android:textSize="15sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etRemoteKeyword"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_search_box"
        android:hint="Rechercher par nom ou numéro"
        android:inputType="text"
        android:singleLine="true"
        android:textColor="@color/aura_text_dark"
        android:textColorHint="#8B7CC7"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnRemoteSearch"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_button_primary"
        android:text="Rechercher dans la base distante"
        android:textAllCaps="false"
        android:textColor="@color/aura_white"
        android:textSize="15sp"
        android:textStyle="bold" />

    <ProgressBar
        android:id="@+id/auraProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginTop="12dp"
        android:indeterminate="true"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAuraContacts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="10dp" />

</LinearLayout>